{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 37 "Ech:=[random[normald[175,10]
](5000)]:" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 19 "mo::array[1..5
000];" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#'%#moG&%&arrayG6#;\"\"\"\"%+]
